# Photo Vault configuration
# Copy to ~/.photovault/config.toml and fill in your values.
# Environment variables override any setting here.

catalog_path   = "~/.photovault/catalog.json"
external_root  = "/Volumes/MyDisk"
redundancy_pct = 10

[b2]
key_id  = "your-key-id"
app_key = "your-app-key"
bucket  = "your-bucket"
