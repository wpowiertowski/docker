# Charles Schwab API credentials
# Obtain from https://developer.schwab.com
SCHWAB_APP_KEY=your_app_key_here
SCHWAB_APP_SECRET=your_app_secret_here

# OAuth callback URL (must match what's registered in Schwab developer portal)
# For local dev the container exposes port 8182
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182

# Path inside the container where the OAuth token file is stored
SCHWAB_TOKEN_PATH=/app/tokens/token.json

# Trading configuration
TRADING_MODE=paper          # paper | live
MAX_POSITION_SIZE=1000      # max USD per position
LOG_LEVEL=INFO
